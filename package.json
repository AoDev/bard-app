{
  "name": "bard",
  "productName": "Bard",
  "version": "0.0.1",
  "description": "A framework based on mobx / react",
  "main": "main.js",
  "scripts": {
    "bundle-analysis": "webpack-bundle-analyzer ./webpack.stats.json ./dist -m server",
    "bundle-stats": "npm run compile -- --profile --json > webpack.stats.json",
    "compile": "cross-env NODE_ENV=production node ./node_modules/webpack/bin/webpack --config webpack.config.production.js --profile --colors",
    "dev": "cross-env NODE_ENV=development node --max_old_space_size=2096 server.js",
    "icon-gen": "icon-gen -i ./src/assets/images/app-icon-source.svg -o ./buildResources -m ico,icns -n ico=icon,icns=icon -s icns=[16,24,32,48,64,96,128,256,512,1024] -r",
    "lint:css": "stylelint \"src/**/*.less\"",
    "lint:js": "eslint src --quiet",
    "lint": "npm run lint:js && npm run lint:css",
    "package:web": "cross-env npm run compile",
    "tag-release": "npm run test-e2e && standard-version",
    "test": "npm run test-unit && npm run test-e2e",
    "test-unit": "jest src",
    "test-e2e": "TEST_INTEGRATION=true jest ./test/e2e.spec.js --runInBand",
    "trash:release": "./dist"
  },
  "bin": {},
  "repository": {
    "type": "git",
    "url": "git@github.com:AoDev/bard.git"
  },
  "author": {
    "name": "Kevin Purnelle",
    "email": "kevin.purnelle@gmail.com",
    "url": "https://github.com/AoDev"
  },
  "license": "MIT",
  "bugs": {
    "url": ""
  },
  "keywords": [
    "mobx",
    "react"
  ],
  "homepage": "",
  "readmeBeforeDepsUpdate": "Updating react-hot-loader to 4.x lead to multiple problems. Good luck if you want to try. || Mobx v4.x is used for browsers that dont support proxies. Update major only if you don't care. || In general, be careful with a new major version which is at 0, like 1.1.2 -> 2.0.0, they are usually buggy. Wait for first fixes.",
  "devDependencies": {
    "@babel/core": "7.8.7",
    "@babel/plugin-proposal-class-properties": "7.8.3",
    "@babel/plugin-proposal-decorators": "7.8.3",
    "@babel/plugin-syntax-dynamic-import": "7.8.3",
    "@babel/polyfill": "7.8.7",
    "@babel/preset-env": "7.8.7",
    "@babel/preset-react": "7.8.3",
    "@babel/register": "7.8.6",
    "@babel/runtime": "7.8.7",
    "@loadable/component": "3.0.2",
    "@types/jest": "25.1.4",
    "axios": "0.18.0",
    "babel-core": "7.0.0-bridge.0",
    "babel-eslint": "10.1.0",
    "babel-jest": "25.1.0",
    "babel-loader": "8.0.6",
    "babel-plugin-lodash": "3.3.4",
    "babel-plugin-module-resolver": "3.2.0",
    "babel-plugin-transform-react-remove-prop-types": "0.4.24",
    "bard-instruments": "1.0.1",
    "bard-router": "1.0.3",
    "classnames": "2.2.6",
    "clean-webpack-plugin": "3.0.0",
    "copy-webpack-plugin": "5.1.1",
    "core-js": "3.6.4",
    "cross-env": "5.2.0",
    "css-loader": "3.4.2",
    "dotenv": "6.2.0",
    "enzyme": "3.11.0",
    "enzyme-adapter-react-16": "1.15.2",
    "eslint": "6.8.0",
    "eslint-config-standard": "14.1.0",
    "eslint-import-resolver-babel-module": "5.1.2",
    "eslint-loader": "3.0.3",
    "eslint-plugin-import": "2.20.1",
    "eslint-plugin-lodash": "6.0.0",
    "eslint-plugin-node": "10.0.0",
    "eslint-plugin-promise": "4.2.1",
    "eslint-plugin-react": "7.19.0",
    "eslint-plugin-standard": "4.0.1",
    "express": "4.17.1",
    "file-loader": "4.2.0",
    "html-webpack-plugin": "3.2.0",
    "jest": "25.1.0",
    "jsdom": "11.12.0",
    "json-loader": "0.5.7",
    "less": "3.11.1",
    "less-loader": "4.1.0",
    "less-plugin-clean-css": "1.5.1",
    "localforage": "1.7.3",
